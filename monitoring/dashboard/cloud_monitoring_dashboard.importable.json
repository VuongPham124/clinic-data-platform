{
  "displayName": "Clinic Data Platform - Ops Monitor (Custom Metrics Only)",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 12,
        "height": 2,
        "widget": {
          "title": "Read Me First",
          "text": {
            "content": "This dashboard uses ONLY exporter metrics from custom.googleapis.com/ops/* .\\n\\nPrerequisites:\\n1) Scheduled queries write to ops_monitor.* tables.\\n2) Exporter job monitoring/exporter/ops_monitor_to_custom_metrics.py runs periodically.\\n3) Replace project_id filter if needed."
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 2,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Watermark Staleness (mins)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"custom.googleapis.com/ops/watermark/mins_since_update\" resource.type=\"global\" resource.label.\"project_id\"=\"wata-clinicdataplatform-gcp\"",
                    "aggregation": {
                      "alignmentPeriod": "300s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "groupByFields": [
                        "metric.label.\"table_name\""
                      ]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "timeshiftDuration": "0s",
            "yAxis": {
              "label": "minutes",
              "scale": "LINEAR"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 2,
        "width": 6,
